{
  "name": "unbound",
  "version": "0.1.0",
  "description": "A publicly visible, cryptographically pseudonymous platform for unrestricted expression",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "crypto": "^1.0.1",
    "bip39": "^3.1.0",
    "secp256k1": "^5.0.0",
    "ws": "^8.14.2",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  },
  "keywords": ["anonymous", "cryptographic", "free-speech", "decentralized"],
  "author": "Unbound Team",
  "license": "MIT"
}