# Generated JWT Secrets
# Add these to your .env file and keep them secure

# IMPORTANT: Generate your own secrets (64+ chars) for real deployments.
# Example generator:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=GENERATE_NEW_64_CHAR_HEX_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_NEW_64_CHAR_HEX_SECRET_HERE

# Security Configuration
NODE_ENV=production
PORT=3000
DATABASE_URL=sqlite:./database.sqlite

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Auth Rate Limiting (stricter)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# Database Security
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000
DB_MAX_LIFETIME=3600000

# Allowed Origins
ALLOWED_ORIGINS=http://localhost:5174,https://yourdomain.com
