# Security Configuration Template
# Copy this to .env and generate your own secrets

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# SQLite (Development)
DATABASE_URL=sqlite:./unbound.db

# PostgreSQL (Production - uncomment for production)
# DATABASE_URL=postgresql://username:password@hostname:5432/database_name
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=unbound
# DB_USER=unbound_user
# DB_PASSWORD=your_secure_password

# Security Configuration
# IMPORTANT: Generate your own secure secrets before production deployment
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=GENERATE_NEW_64_CHAR_HEX_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_NEW_64_CHAR_HEX_SECRET_HERE
CORS_ORIGIN=http://localhost:5174

# Rate Limiting (per 15 minutes)
RATE_LIMIT_POSTS=10
RATE_LIMIT_EDITS=20
RATE_LIMIT_GENERAL=100

# WebSocket Configuration
WS_PATH=/socket.io

# Monitoring Configuration
LOG_LEVEL=info
ENABLE_METRICS=true

# Redis Configuration (Optional - for caching and rate limiting)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Content Moderation
MAX_CONTENT_LENGTH=10000
ENABLE_CONTENT_MODERATION=true

# SSL Configuration (for production)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Backup Configuration
# BACKUP_INTERVAL=3600000
# BACKUP_PATH=/backups

# Additional Security Headers
ENABLE_HELMET=true
ENABLE_CSP=true
SESSION_SECRET=GENERATE_NEW_64_CHAR_HEX_SECRET_HERE