# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# SQLite (Development)
DATABASE_URL=sqlite:./unbound.db

# PostgreSQL (Production - uncomment for production)
# DATABASE_URL=postgresql://username:password@hostname:5432/database_name
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=unbound
# DB_USER=unbound_user
# DB_PASSWORD=your_secure_password

# Security Configuration
# JWT Secrets (generate new secrets for production)
JWT_ACCESS_SECRET=your_super_secure_jwt_access_secret_min_64_chars_change_this_in_production
JWT_REFRESH_SECRET=your_super_secure_jwt_refresh_secret_min_64_chars_change_this_in_production
CORS_ORIGIN=http://localhost:5174

# Rate Limiting (per 15 minutes)
RATE_LIMIT_POSTS=10
RATE_LIMIT_EDITS=20
RATE_LIMIT_GENERAL=100

# WebSocket Configuration
WS_PATH=/socket.io

# Monitoring Configuration
LOG_LEVEL=info
ENABLE_METRICS=true

# Redis Configuration (Optional - for caching and rate limiting)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Content Moderation
MAX_CONTENT_LENGTH=10000
ENABLE_CONTENT_MODERATION=true

# SSL Configuration (for production)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Backup Configuration
# BACKUP_INTERVAL=3600000
# BACKUP_PATH=/backups